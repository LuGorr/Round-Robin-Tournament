    {
      "cell_type": "code",
      "source": [
        "\n",
        "\n",
        "# Function to display solution\n",
        "def display_solution(n_val):\n",
        "    \"\"\"Display the tournament schedule if solution is found\"\"\"\n",
        "    if not ampl.get_objective('total_games').value():\n",
        "        print(\"No solution to display\")\n",
        "        return\n",
        "\n",
        "    print(f\"\\n=== Tournament Schedule for n={n_val} ===\")\n",
        "\n",
        "    # Get solution values\n",
        "    x_vals = ampl.get_variable('x').get_values().to_dict()\n",
        "\n",
        "    W = n_val - 1\n",
        "    P = n_val // 2\n",
        "\n",
        "    for w in range(1, W + 1):\n",
        "        print(f\"\\nWeek {w}:\")\n",
        "        for p in range(1, P + 1):\n",
        "            m = (w - 1) * P + p\n",
        "            print(f\"  Period {p}: \", end=\"\")\n",
        "\n",
        "            # Find the game for this match\n",
        "            game_found = False\n",
        "            for i in range(1, n_val + 1):\n",
        "                for j in range(1, n_val + 1):\n",
        "                    if i != j and (i, j, m) in x_vals and x_vals[(i, j, m)] > 0.5:\n",
        "                        print(f\"Team {i} (home) vs Team {j} (away)\")\n",
        "                        game_found = True\n",
        "                        break\n",
        "                if game_found:\n",
        "                    break\n",
        "\n",
        "            if not game_found:\n",
        "                print(\"No game assigned\")\n",
        "\n"
      ],
      "metadata": {
        "id": "wwu_d2mpnU5a"
      },
      "execution_count": 4,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Test configuration\n",
        "test_cases = [\n",
        "    {'n': 4, 'solvers': ['cbc', 'highs']},\n",
        "    {'n': 6, 'solvers': ['cbc', 'highs']},\n",
        "    {'n': 8, 'solvers': ['cbc', 'highs']},\n",
        "    {'n': 10, 'solvers': ['cbc']},\n",
        "    {'n': 12, 'solvers': ['cbc']},\n",
        "    {'n': 14, 'solvers': ['cbc']},\n",
        "    {'n': 16, 'solvers': ['cbc']}# Only test CBC for larger instances\n",
        "]\n",
        "\n",
        "# Try to add Gurobi and CPLEX if available\n",
        "try:\n",
        "    ampl.option['solver'] = 'gurobi'\n",
        "    ampl.eval('var test_var; minimize test_obj: test_var;')\n",
        "    ampl.solve()\n",
        "    # If no error, Gurobi is available\n",
        "    for case in test_cases[:2]:  # Only test on smaller instances\n",
        "        if 'gurobi' not in case['solvers']:\n",
        "            case['solvers'].append('gurobi')\n",
        "    print(\"Gurobi detected and added to test suite\")\n",
        "except:\n",
        "    print(\"Gurobi not available\")\n",
        "\n",
        "try:\n",
        "    ampl.option['solver'] = 'cplex'\n",
        "    ampl.eval('var test_var; minimize test_obj: test_var;')\n",
        "    ampl.solve()\n",
        "    # If no error, CPLEX is available\n",
        "    for case in test_cases[:2]:  # Only test on smaller instances\n",
        "        if 'cplex' not in case['solvers']:\n",
        "            case['solvers'].append('cplex')\n",
        "    print(\"CPLEX detected and added to test suite\")\n",
        "except:\n",
        "    print(\"CPLEX not available\")\n",
        "\n",
        "# Run experiments\n",
        "results = []\n",
        "print(\"Starting tournament scheduling experiments...\\n\")\n",
        "\n",
        "for case in test_cases:\n",
        "    n_val = case['n']\n",
        "    print(f\"Testing n = {n_val} teams ({n_val*(n_val-1)//2} matches, {n_val-1} weeks, {n_val//2} periods/week)\")\n",
        "\n",
        "    for solver in case['solvers']:\n",
        "        print(f\"  Solver: {solver}\")\n",
        "\n",
        "        status, solve_time, obj_val, feasible = solve_tournament(n_val, solver, time_limit=300)\n",
        "\n",
        "        results.append({\n",
        "            'n': n_val,\n",
        "            'solver': solver,\n",
        "            'status': status,\n",
        "            'solve_time': round(solve_time, 2),\n",
        "            'objective': obj_val,\n",
        "            'feasible': feasible\n",
        "        })\n",
        "\n",
        "        print(f\"    Status: {status}\")\n",
        "        print(f\"    Time: {solve_time:.2f} seconds\")\n",
        "        print(f\"    Objective: {obj_val}\")\n",
        "        print(f\"    Feasible: {feasible}\")\n",
        "\n",
        "        # Display solution for small instances if feasible\n",
        "        if feasible and n_val <= 6:\n",
        "            display_solution(n_val)\n",
        "\n",
        "        print()\n",
        "\n",
        "# Create results summary\n",
        "df_results = pd.DataFrame(results)\n",
        "print(\"\\n\" + \"=\"*60)\n",
        "print(\"EXPERIMENT RESULTS SUMMARY\")\n",
        "print(\"=\"*60)\n",
        "print(df_results.to_string(index=False))\n",
        "\n",
        "# Performance analysis\n",
        "print(\"\\n\" + \"=\"*60)\n",
        "print(\"PERFORMANCE ANALYSIS\")\n",
        "print(\"=\"*60)\n",
        "\n",
        "# Best solver for each n\n",
        "for n_val in df_results['n'].unique():\n",
        "    n_results = df_results[df_results['n'] == n_val]\n",
        "    feasible_results = n_results[n_results['feasible'] == True]\n",
        "\n",
        "    if len(feasible_results) > 0:\n",
        "        best_solver = feasible_results.loc[feasible_results['solve_time'].idxmin()]\n",
        "        print(f\"n={n_val}: Best solver = {best_solver['solver']} ({best_solver['solve_time']}s)\")\n",
        "    else:\n",
        "        print(f\"n={n_val}: No feasible solutions found\")\n",
        "\n",
        "# Overall solver performance\n",
        "print(\"\\nSolver Performance Summary:\")\n",
        "solver_stats = df_results.groupby('solver').agg({\n",
        "    'feasible': ['sum', 'count'],\n",
        "    'solve_time': ['mean', 'std']\n",
        "}).round(2)\n",
        "\n",
        "solver_stats.columns = ['Feasible_Count', 'Total_Attempts', 'Avg_Time', 'Std_Time']\n",
        "solver_stats['Success_Rate'] = (solver_stats['Feasible_Count'] / solver_stats['Total_Attempts'] * 100).round(1)\n",
        "print(solver_stats)\n",
        "\n",
        "print(\"\\nExperiment completed!\")"
      ],
