      "source": [
        "%pip install -q amplpy\n",
        "\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from amplpy import AMPL, Environment,ampl_notebook, DataFrame\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "\n",
        "ampl = ampl_notebook(\n",
        "    modules=[\"highs\", \"cbc\", \"gurobi\", \"cplex\"], # pick from over 20 modules including most commercial and open-source solvers\n",
        "    license_uuid=\"your_license")\n"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Define the AMPL model as a string\n",
        "model_code = \"\"\"\n",
        "# Tournament Scheduling MILP Model\n",
        "\n",
        "# Parameters\n",
        "param n integer > 0, even;  # Number of teams\n",
        "param W := n - 1;           # Number of weeks\n",
        "param P := n / 2;           # Number of periods per week\n",
        "param M := n * (n - 1) / 2; # Total number of matches\n",
        "\n",
        "# Sets\n",
        "set Teams := 1..n;\n",
        "set Weeks := 1..W;\n",
        "set Periods := 1..P;\n",
        "set Matches := 1..M;\n",
        "\n",
        "# Helper function to get match index from week and period\n",
        "param match_index{w in Weeks, p in Periods} := (w-1) * P + p;\n",
        "\n",
        "# Decision variables\n",
        "var x{i in Teams, j in Teams, m in Matches: i != j} binary;\n",
        "\n",
        "# Objective (feasibility problem)\n",
        "minimize total_games: sum{i in Teams, j in Teams, m in Matches: i != j} x[i,j,m];\n",
        "\n",
        "# Constraint 1: Each match has exactly one game\n",
        "subject to one_game_per_match{m in Matches}:\n",
        "    sum{i in Teams, j in Teams: i != j} x[i,j,m] = 1;\n",
        "\n",
        "# Constraint 2: Each pair plays exactly once\n",
        "subject to each_pair_once{i in Teams, j in Teams: i < j}:\n",
        "    sum{m in Matches} (x[i,j,m] + x[j,i,m]) = 1;\n",
        "\n",
        "# Constraint 3: Each team plays once per week\n",
        "subject to one_game_per_week{i in Teams, w in Weeks}:\n",
        "    sum{j in Teams, p in Periods: j != i} (x[i,j,match_index[w,p]] + x[j,i,match_index[w,p]]) = 1;\n",
        "\n",
        "# Constraint 4: At most two games per team per period\n",
        "subject to max_two_per_period{i in Teams, p in Periods}:\n",
        "    sum{w in Weeks, j in Teams: j != i} (x[i,j,match_index[w,p]] + x[j,i,match_index[w,p]]) <= 2;\n",
        "\n",
        "# Symmetry breaking constraint 1: Fix first game\n",
        "subject to fix_first_game:\n",
        "    x[1,2,1] = 1;\n",
        "\n",
        "# Symmetry breaking constraint 2: Period ordering in first week\n",
        "subject to period_ordering{p in 1..(P-1)}:\n",
        "    sum{i in Teams, j in Teams: j != i} i * x[i,j,match_index[1,p]] + 1 <=\n",
        "    sum{i in Teams, j in Teams: j != i} i * x[i,j,match_index[1,p+1]];\n",
        "\n",
        "# Symmetry breaking constraint 3: Team i appears in period i (for i <= P)\n",
        "subject to team_in_period{p in Periods}:\n",
        "    sum{w in Weeks, j in Teams: j != p} (x[p,j,match_index[w,p]] + x[j,p,match_index[w,p]]) >= 1;\n",
        "\"\"\""
      ],
      "metadata": {
        "id": "SdGn547Vw4Vl"
      },
      "execution_count": 2,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Function to solve the problem for given n and solver\n",
        "def solve_tournament(n_val, solver_name, time_limit=300):\n",
        "    \"\"\"\n",
        "    Solve tournament scheduling problem for given n and solver\n",
        "    Returns: (status, solve_time, objective_value, feasible)\n",
        "    \"\"\"\n",
        "    try:\n",
        "        # Clear previous model\n",
        "        ampl.reset()\n",
        "\n",
        "        # Load model\n",
        "        ampl.eval(model_code)\n",
        "\n",
        "        # Set parameter\n",
        "        ampl.param['n'] = n_val\n",
        "\n",
        "        # Set solver and options\n",
        "        ampl.option['solver'] = solver_name\n",
        "        ampl.option['timelimit'] = time_limit\n",
        "\n",
        "        if solver_name.lower() == 'gurobi':\n",
        "            ampl.option['gurobi_options'] = f'timelim={time_limit} mipgap=0.01'\n",
        "        elif solver_name.lower() == 'cplex':\n",
        "            ampl.option['cplex_options'] = f'timelimit={time_limit} mipgap=0.01'\n",
        "        elif solver_name.lower() == 'cbc':\n",
        "            ampl.option['cbc_options'] = f'sec={time_limit} ratio=0.01'\n",
        "        elif solver_name.lower() == 'highs':\n",
        "            ampl.option['highs_options'] = f'time_limit={time_limit}'\n",
        "\n",
        "        # Solve\n",
        "        start_time = time.time()\n",
        "        ampl.solve()\n",
        "        solve_time = time.time() - start_time\n",
        "\n",
        "        # Get results\n",
        "        status = ampl.get_value('solve_result')\n",
        "        obj_val = ampl.get_objective('total_games').value() if ampl.get_objective('total_games').value() is not None else 'N/A'\n",
        "\n",
        "        feasible = status in ['solved', 'optimal', 'feasible']\n",
        "\n",
        "        return status, solve_time, obj_val, feasible\n",
        "\n",
        "    except Exception as e:\n",
        "        return f\"Error: {str(e)}\", 0, 'N/A', False"
      ],
      "metadata": {
        "id": "eqUkgbsRxM1y"
      },
      "execution_count": 3,
      "outputs": []
