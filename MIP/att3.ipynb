        "# Cell 2: Create the AMPL model file\n",
        "def create_tournament_model(n_teams):\n",
        "    model_code = \"\"\"\n",
        "    # Tournament Scheduling AMPL Model\n",
        "    # Sequential match numbering: match in period p, week w = (p-1)*(n-1) + w\n",
        "    # Parameters\n",
        "    param n := {n_teams};  # Number of teams (must be even)\n",
        "    param weeks := n - 1;\n",
        "    param periods := n div 2;\n",
        "    param total_matches := n * (n - 1) div 2;\n",
        "\n",
        "    # Sets\n",
        "    set TEAMS := 1..n;\n",
        "    set WEEKS := 1..weeks;\n",
        "    set PERIODS := 1..periods;\n",
        "    set MATCHES := 1..total_matches;\n",
        "\n",
        "    # Helper function to get week from match number\n",
        "    param week{m in MATCHES} := ((m-1) mod weeks) + 1;\n",
        "    # Helper function to get period from match number\n",
        "    param period{m in MATCHES} := ((m-1) div weeks) + 1;\n",
        "\n",
        "    # Sets of matches for each week and period\n",
        "    set MATCHES_IN_WEEK{w in WEEKS} := {m in MATCHES: week[m] = w};\n",
        "    set MATCHES_IN_PERIOD{p in PERIODS} := {m in MATCHES: period[m] = p};\n",
        "\n",
        "  # Decision Variables\n",
        "    var x{i in TEAMS, j in TEAMS, m in MATCHES} binary;\n",
        "\n",
        "    # Objective (feasibility problem - dummy objective)\n",
        "    minimize dummy_obj: 0;\n",
        "\n",
        "    # Constraints\n",
        "\n",
        "    # 1. Each pair of teams plays exactly once\n",
        "    subject to play_once{i in TEAMS, j in TEAMS: i != j}:\n",
        "        sum{m in MATCHES} (x[i,j,m] + x[j,i,m]) = 1;\n",
        "\n",
        "    # 2. Each match has exactly one game\n",
        "    subject to one_game_per_match{m in MATCHES}:\n",
        "        sum{i in TEAMS, j in TEAMS: i != j} x[i,j,m] = 1;\n",
        "\n",
        "  # 3. Each team plays exactly once per week\n",
        "    subject to one_game_per_week{i in TEAMS, w in WEEKS}:\n",
        "        sum{m in MATCHES_IN_WEEK[w], j in TEAMS: j != i} (x[i,j,m] + x[j,i,m]) = 1;\n",
        "\n",
        "    # 4. Each team plays at most twice in the same period across all weeks\n",
        "    subject to max_twice_per_period{i in TEAMS, p in PERIODS}:\n",
        "        sum{m in MATCHES_IN_PERIOD[p], j in TEAMS: j != i} (x[i,j,m] + x[j,i,m]) <= 2;\n",
        "\n",
        "  # 5. No team plays against itself\n",
        "    subject to no_self_play{i in TEAMS, m in MATCHES}:\n",
        "        x[i,i,m] = 0;\n",
        "  \"\"\"\n",
        "\n",
        "  # Load the model\n",
        "    ampl.eval(model_code)\n",
        "\n",
        "    return ampl\n"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "def solve_tournament(n_teams, solver='gurobi', time_limit=300):\n",
        "    \"\"\"\n",
        "    Solve tournament scheduling problem\n",
        "    \"\"\"\n",
        "    print(f\"Creating tournament model for {n_teams} teams...\")\n",
        "\n",
        "    # Create model\n",
        "    ampl = create_tournament_model(n_teams)\n",
        "\n",
        "    # Set solver options\n",
        "    ampl.option['solver'] = solver\n",
        "    ampl.option['gurobi_options'] = f'timelim={time_limit}'\n",
        "\n",
        "    # Solve\n",
        "    print(\"Solving...\")\n",
        "    import time\n",
        "    start_time = time.time()\n",
        "    ampl.solve()\n",
        "    solve_time = time.time() - start_time\n",
        "\n",
        "    # Get solution status\n",
        "    solve_result = ampl.get_value('solve_result')\n",
        "\n",
        "    print(f\"Solve time: {solve_time:.2f} seconds\")\n",
        "    print(f\"Status: {solve_result}\")\n",
        "\n",
        "    if solve_result == 'solved':\n",
        "        return extract_solution(ampl, n_teams, solve_time)\n",
        "    else:\n",
        "        print(\"No solution found!\")\n",
        "        return None"
      ],
      "metadata": {
        "id": "ICgLOrXrtHpF"
      },
