        "# Cell 7: Tournament generator function (FIXED VERSION)\n",
        "def generate_tournament_program(num_teams):\n",
        "    \"\"\"Generate a tournament program for specified number of teams\"\"\"\n",
        "    if num_teams % 2 != 0:\n",
        "        print(f\"❌ Error: Number of teams ({num_teams}) must be even!\")\n",
        "        return\n",
        "\n",
        "    # Create data file with specified number of teams\n",
        "    data_content = f\"param n := {num_teams};\"\n",
        "    with open('tournament.dat', 'w') as f:\n",
        "        f.write(data_content)\n",
        "\n",
        "    # Use full path to AMPL\n",
        "    ampl = AMPL()\n",
        "    ampl_path = ampl\n",
        "\n",
        "\n",
        "# Generate tournament programs for different team counts\n",
        "print(\"🏆 TOURNAMENT PROGRAM GENERATOR\")\n",
        "print(\"=\" * 70)\n",
        "\n",
        "# Generate programs for common team counts\n",
        "team_counts = [6, 8, 10 , 12]  # Add more if needed: [4, 6, 8, 10, 12]\n",
        "\n",
        "for i, teams in enumerate(team_counts):\n",
        "    if i > 0:\n",
        "        print(\"\\\\n\" + \"=\" * 70)\n",
        "        print(\"=\" * 70)\n",
        "    generate_tournament_program(teams)"
      ]
    },
