        "    printf \"█                    TOURNAMENT PROGRAM                        █\\\\n\";\n",
        "    printf \"████████████████████████████████████████████████████████████████\\\\n\";\n",
        "    printf \"█  %d Teams • %d Weeks • %d Periods per Week • %d Total Games    █\\\\n\", n, W, P, M;\n",
        "    printf \"████████████████████████████████████████████████████████████████\\\\n\\\\n\";\n",
        "\n",
        "    # Weekly schedule\n",
        "    for {w in WEEKS} {\n",
        "        printf \"╔══════════════════════════════════════════════════════════════╗\\\\n\";\n",
        "        printf \"║                         WEEK %2d                              ║\\\\n\", w;\n",
        "        printf \"╠══════════════════════════════════════════════════════════════╣\\\\n\";\n",
        "\n",
        "        for {p in PERIODS} {\n",
        "            printf \"║ Period %d:                                                  ║\\\\n\", p;\n",
        "            for {m in MATCHES_IN_WEEK[w]: period[m] = p} {\n",
        "                for {i in TEAMS, j in TEAMS: i != j && x[i,j,m] > 0.5} {\n",
        "                    printf \"║   Match %2d: Team %2d (HOME) vs Team %2d (AWAY)            ║\\\\n\", m, i, j;\n",
        "                }\n",
        "            }\n",
        "            if p < P then printf \"║                                                            ║\\\\n\";\n",
        "        }\n",
        "        printf \"╚══════════════════════════════════════════════════════════════╝\\\\n\\\\n\";\n",
        "    }\n",
        "\n",
        "    # Team fixture list\n",
        "    printf \"╔══════════════════════════════════════════════════════════════╗\\\\n\";\n",
        "    printf \"║                      TEAM FIXTURES                           ║\\\\n\";\n",
        "    printf \"╚══════════════════════════════════════════════════════════════╝\\\\n\\\\n\";\n",
        "\n",
        "    for {i in TEAMS} {\n",
        "        printf \"TEAM %2d FIXTURES:\\\\n\", i;\n",
        "        printf \"─────────────────────────────────────────────────────────────\\\\n\";\n",
        "        for {w in WEEKS} {\n",
        "            for {m in MATCHES_IN_WEEK[w], j in TEAMS: j != i} {\n",
        "                if x[i,j,m] > 0.5 then\n",
        "                    printf \"Week %2d, Period %d: vs Team %2d (HOME)\\\\n\", w, period[m], j;\n",
        "                else if x[j,i,m] > 0.5 then\n",
        "                    printf \"Week %2d, Period %d: vs Team %2d (away)\\\\n\", w, period[m], j;\n",
        "            }\n",
        "        }\n",
        "        printf \"\\\\n\";\n",
        "    }\n",
        "\n",
        "    # Quick reference table\n",
        "    printf \"╔══════════════════════════════════════════════════════════════╗\\\\n\";\n",
        "    printf \"║                    QUICK REFERENCE                           ║\\\\n\";\n",
        "    printf \"╠══════════════════════════════════════════════════════════════╣\\\\n\";\n",
        "    printf \"║ Match # │ Week │ Period │        Matchup                   ║\\\\n\";\n",
        "    printf \"╠─────────┼──────┼────────┼──────────────────────────────────╣\\\\n\";\n",
        "\n",
        "    for {m in MATCHES} {\n",
        "        for {i in TEAMS, j in TEAMS: i != j && x[i,j,m] > 0.5} {\n",
        "            printf \"║   %2d    │  %2d  │   %2d   │ Team %2d (H) vs Team %2d (A) ║\\\\n\", m, week[m], period[m], i, j;\n",
        "        }\n",
        "    }\n",
        "    printf \"╚══════════════════════════════════════════════════════════════╝\\\\n\\\\n\";\n",
        "\n",
        "    # Statistics\n",
        "    printf \"╔══════════════════════════════════════════════════════════════╗\\\\n\";\n",
        "    printf \"║                      STATISTICS                              ║\\\\n\";\n",
        "    printf \"╠══════════════════════════════════════════════════════════════╣\\\\n\";\n",
        "    printf \"║ Total games per team: %2d                                   ║\\\\n\", n-1;\n",
        "    printf \"║ Home games per team: %2d-%2d                                ║\\\\n\", (n-1) div 2, (n-1) - ((n-1) div 2);\n",
        "    printf \"║ Away games per team: %2d-%2d                                ║\\\\n\", (n-1) div 2, (n-1) - ((n-1) div 2);\n",
        "    printf \"║ Games per week: 1 per team                                  ║\\\\n\";\n",
        "    printf \"║ Max games per period: 2 per team                            ║\\\\n\";\n",
        "    printf \"╚══════════════════════════════════════════════════════════════╝\\\\n\\\\n\";\n",
        "\n",
        "} else {\n",
        "    printf \"\\\\n❌ ERROR: Could not find a valid tournament schedule!\\\\n\";\n",
        "    printf \"Solution status: %s\\\\n\", solve_result;\n",
        "    printf \"Solver used: %s\\\\n\", Current.solver;\n",
        "    printf \"\\\\nTrying alternative approach...\\\\n\";\n",
        "\n",
        "    # Try relaxing some constraints or using different solver\n",
        "    printf \"This might happen with certain team counts.\\\\n\";\n",
        "    printf \"The problem may be infeasible or the solver had issues.\\\\n\";\n",
        "}\n",
        "\n",
        "quit;\n",
        "\"\"\"\n",
        "ampl.eval(model_code)\n",
        "\n",
        "with open('run_tournament.run', 'w') as f:\n",
        "    f.write(run_code)\n",
        "\n",
        "print(\"Run script created: run_tournament.run\")\n",
        "\n"
      ]
