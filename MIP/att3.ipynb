        "\n",
        "print(\"Data file created: tournament.dat\")\n",
        "\n",
        "# Cell 4: Create the run script (FIXED FOR COLAB)\n",
        "run_code = \"\"\"\n",
        "# Load model and data\n",
        "model tournament.mod;\n",
        "data tournament.dat;\n",
        "\n",
        "# Set solver options - use HiGHS solver which works better in Colab\n",
        "option solver highs;\n",
