      "source": [
        "# Cell 8: Python alternative using OR-Tools (BACKUP SOLUTION)\n",
        "from ortools.linear_solver import pywraplp\n",
        "import itertools\n",
        "\n",
        "def solve_tournament_python(n):\n",
        "    \"\"\"Solve tournament scheduling using OR-Tools in Python\"\"\"\n",
        "    print(f\"🐍 Solving {n}-team tournament using Python OR-Tools...\")\n",
        "\n",
        "    if n % 2 != 0:\n",
        "        print(f\"❌ Error: Number of teams ({n}) must be even!\")\n",
        "        return None\n",
        "\n",
        "    W = n - 1  # weeks\n",
        "    P = n // 2  # periods per week\n",
        "    M = W * P  # total matches\n",
        "\n",
        "    # Create solver\n",
        "    solver = pywraplp.Solver.CreateSolver('SCIP')\n",
        "    if not solver:\n",
        "        print(\"❌ Could not create OR-Tools solver\")\n",
        "        return None\n",
        "\n",
        "    # Helper functions\n",
        "    def week_from_match(m): return ((m-1) % W) + 1\n",
        "    def period_from_match(m): return ((m-1) // W) + 1\n",
        "\n",
        "    # Decision variables\n",
        "    x = {}\n",
        "    for i in range(1, n+1):\n",
        "        for j in range(1, n+1):\n",
        "            for m in range(1, M+1):\n",
        "                x[i,j,m] = solver.BoolVar(f'x_{i}_{j}_{m}')\n",
        "\n",
        "    # Constraints\n",
        "\n",
        "    # 1. Each pair plays exactly once\n",
        "    for i in range(1, n+1):\n",
        "        for j in range(1, n+1):\n",
        "            if i != j:\n",
        "                solver.Add(sum(x[i,j,m] + x[j,i,m] for m in range(1, M+1)) == 1)\n",
        "\n",
        "    # 2. Each match has exactly one game\n",
        "    for m in range(1, M+1):\n",
        "        solver.Add(sum(x[i,j,m] for i in range(1, n+1) for j in range(1, n+1) if i != j) == 1)\n",
        "\n",
        "    # 3. Each team plays once per week\n",
        "    for i in range(1, n+1):\n",
        "        for w in range(1, W+1):\n",
        "            matches_in_week = [m for m in range(1, M+1) if week_from_match(m) == w]\n",
        "            solver.Add(sum(x[i,j,m] + x[j,i,m]\n",
        "                          for m in matches_in_week\n",
        "                          for j in range(1, n+1) if j != i) == 1)\n",
        "\n",
        "    # 4. At most twice per period\n",
        "    for i in range(1, n+1):\n",
        "        for p in range(1, P+1):\n",
        "            matches_in_period = [m for m in range(1, M+1) if period_from_match(m) == p]\n",
        "            solver.Add(sum(x[i,j,m] + x[j,i,m]\n",
        "                          for m in matches_in_period\n",
        "                          for j in range(1, n+1) if j != i) <= 2)\n",
        "\n",
        "    # 5. No self-play\n",
        "    for i in range(1, n+1):\n",
        "        for m in range(1, M+1):\n",
        "            solver.Add(x[i,i,m] == 0)\n",
        "\n",
        "    # Solve\n",
        "    print(\"Solving...\")\n",
        "    status = solver.Solve()\n",
        "\n",
        "    if status == pywraplp.Solver.OPTIMAL or status == pywraplp.Solver.FEASIBLE:\n",
        "        print(\"✅ Solution found!\")\n",
        "\n",
        "        # Extract solution\n",
        "        schedule = {}\n",
        "        for m in range(1, M+1):\n",
        "            for i in range(1, n+1):\n",
        "                for j in range(1, n+1):\n",
        "                    if i != j and x[i,j,m].solution_value() > 0.5:\n",
        "                        schedule[m] = (i, j)  # i plays home vs j\n",
        "                        break\n",
        "\n",
        "        return schedule, n, W, P, M\n",
        "    else:\n",
        "        print(f\"❌ No solution found. Status: {status}\")\n",
        "        return None\n",
        "\n",
        "def print_tournament_program_python(solution_data):\n",
        "    \"\"\"Print tournament program from Python solution\"\"\"\n",
        "    if not solution_data:\n",
        "        return\n",
        "\n",
        "    schedule, n, W, P, M = solution_data\n",
        "\n",
        "    print(\"\\\\n\" + \"█\" * 64)\n",
        "    print(\"█\" + \" \" * 20 + \"TOURNAMENT PROGRAM\" + \" \" * 24 + \"█\")\n",
        "    print(\"█\" * 64)\n",
        "    print(f\"█  {n} Teams • {W} Weeks • {P} Periods per Week • {M} Total Games\" + \" \" * (64 - len(f\"█  {n} Teams • {W} Weeks • {P} Periods per Week • {M} Total Games\")) + \"█\")\n",
        "    print(\"█\" * 64)\n",
        "\n",
        "    # Weekly schedule\n",
        "    for w in range(1, W+1):\n",
        "        print(\"\\\\n╔\" + \"═\" * 62 + \"╗\")\n",
        "        print(f\"║{' ' * 25}WEEK {w:2d}{' ' * 25}║\")\n",
        "        print(\"╠\" + \"═\" * 62 + \"╣\")\n",
        "\n",
        "        for p in range(1, P+1):\n",
        "            print(f\"║ Period {p}:{' ' * 53}║\")\n",
        "            # Find matches in this week and period\n",
        "            for m in range(1, M+1):\n",
        "                week_m = ((m-1) % W) + 1\n",
        "                period_m = ((m-1) // W) + 1\n",
        "                if week_m == w and period_m == p and m in schedule:\n",
        "                    home, away = schedule[m]\n",
        "                    print(f\"║   Match {m:2d}: Team {home:2d} (HOME) vs Team {away:2d} (AWAY){' ' * 12}║\")\n",
        "            if p < P:\n",
        "                print(\"║\" + \" \" * 60 + \"║\")\n",
        "        print(\"╚\" + \"═\" * 62 + \"╝\")\n",
        "\n",
        "# Test the Python solution\n",
        "print(\"\\\\n\" + \"🔄 TRYING PYTHON ALTERNATIVE\" + \"\\\\n\" + \"=\" * 50)\n",
        "\n",
        "for teams in [6, 8, 10,12]:  # Test with smaller numbers first\n",
        "    result = solve_tournament_python(teams)\n",
        "    if result:\n",
        "        print_tournament_program_python(result)\n",
        "        print(\"\\\\n\" + \"=\" * 60)\n",
        "    print()"
      ]
    },
