        "# Cell 3: Create the data file\n",
        "\n",
        "data_code = \"\"\"\n",
        "# Data file for tournament scheduling\n",
        "param n := 2k;  # Change this to test different team counts (must be even)\n",
        "\"\"\"\n",
        "\n",
        "with open('tournament.dat', 'w') as f:\n",
